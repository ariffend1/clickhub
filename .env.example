# Supabase Configuration
# Get these values from your Supabase project settings
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your_anon_key_here

# ⚠️ SECURITY WARNING: BYPASS AUTHENTICATION
# Set to 'true' to bypass authentication on login page (DEVELOPMENT ONLY!)
# DANGER: NEVER SET THIS TO 'true' IN PRODUCTION ENVIRONMENT!
# If set to true, anyone can login to any account (including SUPER_ADMIN) without a password.
VITE_BYPASS_AUTH=false

# Optional: Telegram Bot Configuration
# Leave empty if not using Telegram notifications
VITE_TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
VITE_TELEGRAM_CHAT_ID=your_telegram_chat_id_here

# Optional: Webhook Configuration
# For custom notification webhooks
VITE_WEBHOOK_URL=https://your-webhook-endpoint.com/notify

# Application Environment
# Options: development, staging, production
VITE_APP_ENV=development

# Feature Flags
VITE_ENABLE_OFFLINE_MODE=true
VITE_ENABLE_PWA=true
VITE_ENABLE_NOTIFICATIONS=true
VITE_ENABLE_CHAT=true
VITE_ENABLE_ASSET_MANAGEMENT=true
VITE_ENABLE_EQUIPMENT_CHECKOUT=true
VITE_ENABLE_GOODS_RECEIPT=true
VITE_ENABLE_REPORTS=true